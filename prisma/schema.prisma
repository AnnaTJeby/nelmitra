// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}
model MachineryOwner {
  id        Int      @id @default(autoincrement())
  name      String
  type      String
  location  String
  status    String
  createdAt DateTime @default(now())
}
model Variety {
  id          Int    @id @default(autoincrement())
  name        String
  tag         String
  fit         Int
  duration    String
  yieldAmount String
  pestRisk    String
  availableAt String
}

model Buyer {
  id       Int    @id @default(autoincrement())
  name     String
  price    String
  detail   String
  status   String
  location String
}

model Officer {
  id            Int     @id @default(autoincrement())
  icon          String
  name          String
  detail        String
  hours         String
  showWhatsapp  Boolean @default(false)
}
model HayListing {
  id        Int      @id @default(autoincrement())
  type      String
  name      String
  phone     String
  location  String
  quantity  String
  purpose   String?
  price     String?
  createdAt DateTime @default(now())
}